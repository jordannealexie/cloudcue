PORT=4000
NODE_ENV=production

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require

JWT_SECRET=replace-with-very-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-very-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CLIENT_URL=https://cloudcue.vercel.app
BACKEND_PUBLIC_URL=https://api.cloudcue.app

STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_ACCESS_KEY=replace-with-storage-access-key
STORAGE_SECRET_KEY=replace-with-storage-secret-key
STORAGE_BUCKET=cloudcue-uploads-prod
STORAGE_PUBLIC_URL=https://your-storage-public-base-url

STORAGE_FALLBACK_LOCAL=false
STORAGE_FORCE_LOCAL=false
LOCAL_UPLOAD_TOKEN_SECRET=replace-with-third-very-long-random-secret
STORAGE_SYNC_INTERVAL_MS=60000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.cloudcue.app/api/auth/google/callback

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@your-domain
