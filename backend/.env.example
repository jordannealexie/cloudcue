JWT_SECRET=replace-with-32-char-secret
JWT_REFRESH_SECRET=replace-with-another-32-char-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=development
